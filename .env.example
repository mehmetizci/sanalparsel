# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Storage
# Required for TTS audio uploads - must have Storage admin permissions
# Create bucket 'generated-audio' in Supabase dashboard with public access

# Mapbox (Satellite Maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token

# OpenRouter (AI)
OPENROUTER_API_KEY=your_openrouter_api_key

# ElevenLabs (Voice)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# iyzico (Payments)
IYZIPAY_API_KEY=your_iyzico_api_key
IYZIPAY_SECRET_KEY=your_iyzico_secret_key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render Worker (Optional - for heavy video rendering)
RENDER_WORKER_URL=your_render_worker_url