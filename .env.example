# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Mapbox (Satellite Maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token

# OpenRouter (AI)
OPENROUTER_API_KEY=your_openrouter_api_key

# ElevenLabs (Voice)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# iyzico (Payments)
IYZIPAY_API_KEY=your_iyzico_api_key
IYZIPAY_SECRET_KEY=your_iyzico_secret_key

# Sentry (Error Monitoring)
# Get your DSN from https://sentry.io/settings/<your-org>/projects/<your-project>/keys/
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render TTS Backend (Optional - for production TTS)
# If set, frontend will use this backend instead of /api/generate-tts
VITE_TTS_API_URL=https://sanalparsel.onrender.com

# Render Worker (Optional - for heavy video rendering)
RENDER_WORKER_URL=your_render_worker_url