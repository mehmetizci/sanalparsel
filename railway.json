{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "idleTimeout": 300,
    "gracePeriodSeconds": 30,
    "memoryLimit": 2048,
    "cpuLimit": 1
  }
}