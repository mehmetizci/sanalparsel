# SanalParsel Backend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port to listen on (Railway will override this with PORT env var)
PORT=8080

# Node environment
NODE_ENV=production

# Log level: error, warn, info, debug
LOG_LEVEL=info

# =============================================================================
# RENDERING CONFIGURATION
# =============================================================================

# Number of FFmpeg threads (keep at 1 for Railway 1GB memory limit)
FFPEG_THREADS=1

# Max concurrent renders (keep at 1 for Railway)
MAX_CONCURRENT_RENDERS=1

# Temp file max age in minutes
TEMP_FILE_MAX_AGE=30

# =============================================================================
# STORAGE (Optional - for storing rendered videos)
# =============================================================================

# S3 Compatible Storage (AWS, DigitalOcean Spaces, etc.)
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Or use local filesystem (default)
OUTPUT_PATH=./output

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Webhook URL for job completion notifications
# WEBHOOK_URL=

# Authentication token (optional)
# AUTH_TOKEN=

# =============================================================================
# NOTES
# =============================================================================
#
# For Railway deployment, add these environment variables in the Railway dashboard:
# - PORT (automatically set by Railway)
# - NODE_ENV=production
#
# All other variables have sensible defaults and don't need to be set.
#
# =============================================================================